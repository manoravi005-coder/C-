#include <bits/stdc++.h>
#include <iostream>
#include <vector>
using namespace std;

int main() {
	int n;
	cin >> n;
	int esum = 0, osum =0 ; 
	 for (int i = 1; i <= n; i++) {
        if(i % 2 == 0) esum+=i;
        else if(i%2 != 0) osum += i;
    }
	cout << esum << ' ' << endl << osum << ' '  ;
}
